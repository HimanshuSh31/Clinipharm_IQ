# ── Admin credentials ─────────────────────────────────────────────────────
# Set these before running. If not set, the app falls back to admin/admin.
PHARMACY_ADMIN_USER=admin
PHARMACY_ADMIN_PASS=admin

# ── Low-stock email alerts (optional) ────────────────────────────────────
# Leave blank to disable email notifications.
# For Gmail, generate an App Password at:
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
ALERT_EMAIL=admin@yourpharmacy.com

# ── Logging ───────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Database Scaling (Optional) ──────────────────────────────────────────
# Default is sqlite. Set DB_ENGINE=postgres to use PostgreSQL.
DB_ENGINE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmacy_db
DB_USER=postgres
DB_PASSWORD=postgres
